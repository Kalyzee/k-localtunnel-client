{
  "name": "localtunnel",
  "description": "Expose localhost to the world",
  "version": "3.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/localtunnel/localtunnel.git"
  },
  "author": "Roman Shtylman <shtylman@gmail.com>",
  "contributors": [
    "Roman Shtylman <shtylman@gmail.com>",
    "Gert Hengeveld <gert@hichroma.com>",
    "Tom Coleman <tom@hichroma.com>"
  ],
  "main": "./localtunnel.js",
  "bin": {
    "lt": "bin/lt.js"
  },
  "scripts": {
    "test": "mocha --reporter list --timeout 60000 -- *.spec.js",
    "docker-image-build": "node scripts/docker-image-build.cjs",
    "docker-image-push": "node scripts/docker-image-push.cjs",
    "docker-image-build-push": "node scripts/docker-image-build-and-push.cjs",
    "docker-image-run": "node scripts/docker-image-run.cjs",
    "db": "yarn docker-image-build",
    "dp": "yarn docker-image-push",
    "dbp": "yarn docker-image-build-push"
  },
  "dependencies": {
    "axios": "0.21.4",
    "debug": "4.3.2",
    "openurl": "1.1.1",
    "yargs": "17.1.1"
  },
  "devDependencies": {
    "mocha": "~9.1.1",
    "shelljs": "0.10.0",
    "compare-versions": "6.1.1",
    "dotenv": "17.3.1"
  },
  "engines": {
    "node": ">=8.3.0"
  }
}
